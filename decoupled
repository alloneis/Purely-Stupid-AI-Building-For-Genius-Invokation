import { PureGameEngine } from './pure_engine';
// 导入你的初始卡组和数据...

async function runRandomAI() {
  const engine = new PureGameEngine(gameData, defaultConfig);
  let state = engine.createInitialState(deck1, deck2);
  
  console.log("=== 幻境模拟开始 ===");
  const startTime = Date.now();
  let stepCount = 0;

  // 只要游戏没结束，就一直疯狂自己打自己
  while (!state.isFinished && stepCount < 10000) {
    const actions = engine.getPossibleActions(state);
    
    if (actions.length === 0) {
      console.log("无合法动作，卡死了？");
      break;
    }

    // 随机挑选一个动作（哪怕是最蠢的动作）
    const randomAction = actions[Math.floor(Math.random() * actions.length)];
    
    // 瞬间执行，没有动画，没有等待
    state = await engine.execute(state, randomAction);
    stepCount++;
  }

  const costTime = Date.now() - startTime;
  console.log(`=== 模拟结束 ===`);
  console.log(`总共执行了 ${stepCount} 步动作`);
  console.log(`耗时: ${costTime} 毫秒`);
  console.log(`性能: ${Math.floor(stepCount / (costTime / 1000))} 步/秒`);
  console.log(`赢家: ${state.winner}`);
}

runRandomAI();