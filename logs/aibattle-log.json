第二处：重写 rollout 方法（实现加权引导，摒弃绝对随机和绝对剪枝）
找到 rollout 方法，将其完全替换为以下代码。这是整套 AI 的灵魂：用你的模型做概率加权，引导 MCTS 走向高质量结局。

TypeScript
  private rollout(initial: PureGameState, rootPlayer: 0 | 1, depth: number): number {
    let state = initial;
    let currentDepth = depth;

    while (currentDepth < this.maxDepth && !isTerminalState(state)) {
      const legal = RuleEngine.getPossibleActions(state.gameState, { fastMode: true }).filter(
        (action) => action.validity === ActionValidity.VALID,
      );
      if (legal.length === 0) break;

      const who = state.gameState.currentTurn;
      
      // ===== 核心改动：加权随机采样 (Roulette Wheel Selection) =====
      // 绝不强行剪枝删除动作，而是让高分动作被选中的概率变大
      let totalWeight = 0;
      const weightedActions = legal.map(action => {
        // 利用你写的 quickActionGain 获取该动作的“启发式评分”
        const score = this.pruner["quickActionGain"](action, state.gameState, who);
        
        // 使用指数函数(Softmax思想)把评分转化为正数权重
        // 评分越高的动作，weight 呈指数级放大；评分低的动作 weight 接近于 0 但绝不是 0
        const weight = Math.exp(score * 1.5); 
        totalWeight += weight;
        return { action, weight };
      });

      // 掷骰子，按照权重概率抽取动作
      let roll = this.rng() * totalWeight;
      let selectedAction = weightedActions[0].action;
      for (const wa of weightedActions) {
        roll -= wa.weight;
        if (roll <= 0) {
          selectedAction = wa.action;
          break;
        }
      }
      // ============================================================

      const nextState = this.transition(state, selectedAction);
      if (!nextState) break;

      state = nextState;
      currentDepth += 1;
    }

    // 走到伪结局 (Fake Ending) 后，调用你的量化模型进行评估！
    return this.evaluator.evaluate(state, rootPlayer);
  }
