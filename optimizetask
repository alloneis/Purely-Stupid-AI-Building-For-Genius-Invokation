  private selectChild(node: SearchNode, rootPlayer: 0 | 1): SearchNode {
    const parentVisits = Math.max(1, node.visits);
    const sqrtParentVisits = Math.sqrt(parentVisits);

    let bestChild = node.children[0];
    let bestScore = Number.NEGATIVE_INFINITY;

    // 1. 先把所有子节点的启发式评分转化为概率分布 (Softmax)
    // 这样 P(a) 的总和为 1，代表了 AI 初始的“注意力分配”
    const priorScores = node.children.map(child => {
        if (!child.actionFromParent) return 0;
        return this.pruner["quickActionGain"](child.actionFromParent, node.state.gameState, node.state.gameState.currentTurn);
    });
    const maxPrior = Math.max(...priorScores, 0);
    const expScores = priorScores.map(s => Math.exp(s - maxPrior)); // 减去最大值防止溢出
    const sumExp = expScores.reduce((a, b) => a + b, 0);
    const priorProbabilities = expScores.map(e => e / (sumExp || 1));

    // 2. 使用 PUCT 公式选择节点
    for (let i = 0; i < node.children.length; i++) {
      const child = node.children[i];
      const priorProb = priorProbabilities[i]; // 这就是该动作的“注意力权重”

      const mean = child.visits === 0 ? 0 : child.valueSum / child.visits;
      const minimax = Number.isFinite(child.minimaxValue) ? child.minimaxValue : mean;
      const blended = this.minimaxBlend * minimax + (1 - this.minimaxBlend) * mean;
      
      const exploitation = node.currentPlayer === null || node.currentPlayer === rootPlayer
          ? blended
          : -blended;
          
      // ===== 核心改动：PUCT 探索项 =====
      // c * P(s,a) * sqrt(N) / (1 + n)
      const exploration = this.exploration * priorProb * sqrtParentVisits / (1 + child.visits);
      
      const score = exploitation + exploration;
      if (score > bestScore) {
        bestScore = score;
        bestChild = child;
      }
    }

    return bestChild;
  }

